# External data-source API credentials.
# Copy to `.env` and fill in real values (`.env` is git-ignored).

# Korea Meteorological Administration (KMA) — ASOS daily weather API
# Issued at https://www.data.go.kr (data.go.kr open data portal)
KMA_SERVICE_KEY=

# MOLIT V-World spatial data API — individual land price by parcel
# Issued at https://www.vworld.kr
VWORLD_API_KEY=
